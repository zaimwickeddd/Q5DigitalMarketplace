<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Header Toolbar Frame -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E1E2A"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:paddingHorizontal="20dp">

            <!-- 🛠️ FIXED: Title centered in the middle of the header toolbar -->
            <TextView
                android:id="@+id/tv_brand_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Home"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFF" />

            <LinearLayout
                android:id="@+id/ll_top_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Notifications Button Container -->
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_notif"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="#2A2A35"
                        app:cardElevation="0dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_popup_reminder"
                            app:tint="#60A5FA"
                            android:contentDescription="Notifications" />
                    </com.google.android.material.card.MaterialCardView>

                    <View
                        android:id="@+id/notif_badge"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_alignTop="@id/btn_notif"
                        android:layout_alignEnd="@id/btn_notif"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="#EF4444"
                        android:visibility="gone" />
                </RelativeLayout>

                <!-- Favorites Action Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_favs"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#2A2A35"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/btn_star_big_off"
                        app:tint="#F87171"
                        android:contentDescription="Favorites" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Settings Action Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#2A2A35"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_preferences"
                        app:tint="#9CA3AF"
                        android:contentDescription="Settings" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Content Area Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- 🛠️ FIXED: Greeting Title shifted to the top of the content area -->
        <TextView
            android:id="@+id/tv_greeting_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Welcome back, Najib"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cv_profile_avatar" />

        <!-- 🛠️ FIXED: Subtitle Hint positioned directly beneath the greeting title -->
        <TextView
            android:id="@+id/tv_subtitle_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="View all available items"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting_title"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 🛠️ FIXED: Profile Avatar pinned to align with the top welcome greeting strings -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_profile_avatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="32dp"
            app:cardBackgroundColor="#06B6D4"
            app:cardElevation="0dp"
            app:layout_constraintTop_toTopOf="@id/tv_greeting_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_subtitle_hint"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_home_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="User Avatar" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 🛠️ FIXED: Search bar shifted down to display directly below the greeting layout section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_search_wrapper"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="#1E1E2A"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A35"
            app:strokeWidth="1.5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle_hint"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#9CA3AF"
                    android:contentDescription="Search" />

                <EditText
                    android:id="@+id/search_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search items on campus..."
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:layout_marginStart="16dp"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#9CA3AF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🛠️ FIXED: RecyclerView layout adjusted to populate items below the search bar container -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_explore_items"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:scrollbars="vertical"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/cv_search_wrapper"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_product" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
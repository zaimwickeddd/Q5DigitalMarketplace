<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_brand_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/textColorPrimary"
        app:layout_constraintTop_toTopOf="@id/ll_top_actions"
        app:layout_constraintBottom_toBottomOf="@id/ll_top_actions"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/ll_top_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_notif"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/bg_notif_icon"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notifications_outline"
                    app:tint="#60A5FA" />
            </com.google.android.material.card.MaterialCardView>

            <View
                android:id="@+id/notif_badge"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_alignTop="@id/btn_notif"
                android:layout_alignEnd="@id/btn_notif"
                android:background="@drawable/circle_background"
                android:backgroundTint="#EF4444"
                android:visibility="gone" />
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_favs"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="@color/bg_fav_icon"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_heart_outline"
                app:tint="#F87171" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="@color/bg_settings_icon"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings_outline"
                app:tint="@color/textColorSecondary" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_search_wrapper"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="30dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorSurfaceVariant"
        app:strokeWidth="1.5dp"
        app:layout_constraintTop_toBottomOf="@id/ll_top_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search_outline"
                app:tint="@color/textColorSecondary"/>

            <EditText
                android:id="@+id/search_bar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search items on campus..."
                android:importantForAutofill="no"
                android:inputType="text"
                android:layout_marginStart="16dp"
                android:textSize="16sp"
                android:textColor="@color/textColorPrimary"
                android:textColorHint="@color/textColorSecondary"
                tools:ignore="LabelFor" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_greeting_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Welcome back, Najib"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/textColorPrimary"
        app:layout_constraintTop_toBottomOf="@id/cv_search_wrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cv_profile_avatar" />

    <TextView
        android:id="@+id/tv_subtitle_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="View all available items"
        android:textColor="@color/textColorSecondary"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting_title"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_profile_avatar"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="36dp"
        app:cardBackgroundColor="@color/colorPrimary"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="@id/tv_greeting_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_subtitle_hint"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person_outline"
            app:tint="@color/colorBackground"/>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_explore_items"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle_hint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_product" />

</androidx.constraintlayout.widget.ConstraintLayout>
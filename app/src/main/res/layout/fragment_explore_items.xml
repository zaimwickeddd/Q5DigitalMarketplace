<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/explore_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_explore_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore Items"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/textColorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_open_filters"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorSurfaceVariant"
            app:strokeWidth="1dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="@id/tv_explore_header"
            app:layout_constraintBottom_toBottomOf="@id/tv_explore_header"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/colorPrimary" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_search_wrapper"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorSurfaceVariant"
            app:strokeWidth="1.5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_explore_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search_outline"
                    app:tint="@color/textColorSecondary"/>

                <EditText
                    android:id="@+id/et_search_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search items on campus..."
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:layout_marginStart="16dp"
                    android:textSize="16sp"
                    android:textColor="@color/textColorPrimary"
                    android:textColorHint="@color/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_explore_items_list"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            app:layout_constraintTop_toBottomOf="@id/cv_search_wrapper"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_product" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer Sidebar -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/filter_navigation_sidebar"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        app:menu="@menu/filter_sidebar_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
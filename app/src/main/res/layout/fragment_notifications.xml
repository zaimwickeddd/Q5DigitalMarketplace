<?xml version="1.0" encoding="utf-8"?>
<!-- 🛠️ FIXED: Added a vertical parent container with fitsSystemWindows="true" for safe status bar clearance -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 🛠️ FIXED: Integrated the matching 80dp Dark Theme Header Toolbar framework -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E1E2A"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:paddingHorizontal="20dp">

            <!-- 🛠️ FIXED: Kept exact matching ID while styling button alignment -->
            <ImageView
                android:id="@+id/btn_back_notif"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Notifications"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Notification Content Viewport Container Framework -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- Active Notifications RecyclerView List View node -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_notifications"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_notification" />

        <!-- Fallback Empty State Layout Container UI Banner -->
        <LinearLayout
            android:id="@+id/layout_empty_notif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_notifications_outline"
                app:tint="#2A2A35"
                android:contentDescription="Empty Notification Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No notifications yet"
                android:textColor="#9CA3AF"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <!-- Top Header Navigation bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1E1E2A"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#F9FAFB"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Listing Details"
            android:textColor="#F9FAFB"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A35"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Product Display Media View -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="240dp"
                app:cardBackgroundColor="#1E1E2A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A35"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:id="@+id/detail_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Product Preview" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Metadata Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E2A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A35"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:id="@+id/detail_title_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CATEGORY"
                        android:textColor="#06B6D4"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/detail_title_main"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item Name"
                        android:textColor="#F9FAFB"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="#06B6D4" />
                        <TextView
                            android:id="@+id/detail_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM --"
                            android:textColor="#F9FAFB"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Description -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E2A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A35"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="#F9FAFB"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/detail_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No description provided."
                        android:textColor="#9CA3AF"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seller Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E2A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A35"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Seller Information"
                        android:textColor="#F9FAFB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            app:cardCornerRadius="27dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#06B6D4"
                            app:strokeWidth="1dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/sym_def_app_icon"
                                android:scaleType="centerCrop"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:id="@+id/tv_seller_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Seller"
                                android:textColor="#F9FAFB"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verified Account"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_whatsapp"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Contact Seller"
                        android:textColor="#F9FAFB"
                        android:textStyle="bold"
                        app:backgroundTint="#25D366"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="20dp"
                        app:icon="@android:drawable/stat_notify_chat"
                        app:iconGravity="textStart"
                        app:iconTint="#F9FAFB"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Technical Specifications -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E2A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#2A2A35"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listing Details"
                        android:textColor="#F9FAFB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:text="Category" android:textColor="#9CA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/spec_category" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="--" android:textColor="#F9FAFB" android:textStyle="bold" android:textSize="14sp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A35" android:layout_alignParentBottom="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:text="Condition" android:textColor="#9CA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/spec_condition" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="--" android:textColor="#F9FAFB" android:textStyle="bold" android:textSize="14sp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A35" android:layout_alignParentBottom="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:text="Faculty" android:textColor="#9CA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/spec_faculty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="--" android:textColor="#F9FAFB" android:textStyle="bold" android:textSize="14sp" />
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A35" android:layout_alignParentBottom="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:text="Listing Type" android:textColor="#9CA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/spec_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="--" android:textColor="#F9FAFB" android:textStyle="bold" android:textSize="14sp" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
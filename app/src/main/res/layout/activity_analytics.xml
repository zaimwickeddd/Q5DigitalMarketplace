<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9FC"
    android:padding="20dp"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Market Analytics"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1C1E"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Highest buyer interest based on WhatsApp clicks"
        android:textSize="13sp"
        android:textColor="#74777F"
        android:layout_marginBottom="24dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNoData"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="No analytics data available yet."
            android:gravity="center"
            android:textColor="#74777F"
            android:textSize="14sp"
            android:visibility="gone"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layoutBarsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:divider="?android:attr/dividerHorizontal"
                    android:showDividers="middle"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E2EC"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Listing Breakdown"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total inventory distribution across item categories"
                    android:textSize="12sp"
                    android:textColor="#74777F"
                    android:layout_marginBottom="16dp"/>

                <com.example.q5digitalmarketplace.PieChartView
                    android:id="@+id/pieChartView"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal" />

                <LinearLayout
                    android:id="@+id/layoutPieLegend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="4dp"/>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <Button
        android:id="@+id/btn_back_analytics"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="Back to Profile"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0061A4"
        android:textStyle="bold"/>

</LinearLayout>
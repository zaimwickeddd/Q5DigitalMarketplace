<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="20dp"
    android:fitsSystemWindows="true"
    tools:context=".AnalyticsActivity">

    <TextView
        android:id="@+id/tv_analytics_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Shop Analytics"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#F9FAFB"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Buyer interest insights for your listings"
        android:textSize="13sp"
        android:textColor="#9CA3AF"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#1E1E2A"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#2A2A35"
        app:strokeWidth="1dp"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvNoData"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="No analytics data available yet. List an item to start tracking!"
                android:gravity="center"
                android:textColor="#9CA3AF"
                android:textSize="14sp"
                android:visibility="gone"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category Performance"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F9FAFB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total clicks by item category"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="12dp"/>

                    <!-- Dynamic container for category bar chart rows -->
                    <LinearLayout
                        android:id="@+id/layoutBarsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:divider="@android:color/transparent"
                        android:showDividers="middle"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2A2A35"
                        android:layout_marginVertical="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Inventory Breakdown"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F9FAFB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distribution of your listed items"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="16dp"/>

                    <com.example.q5digitalmarketplace.PieChartView
                        android:id="@+id/pieChartView"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_gravity="center_horizontal" />

                    <!-- Dynamic container for chart legend items -->
                    <LinearLayout
                        android:id="@+id/layoutPieLegend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:paddingHorizontal="4dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2A2A35"
                        android:layout_marginVertical="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item Performance"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F9FAFB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WhatsApp clicks per item"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/layoutItemPerformance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                </LinearLayout>
            </ScrollView>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_analytics"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Back to Profile"
        android:textColor="#121212"
        android:textStyle="bold"
        app:backgroundTint="#06B6D4"
        app:cornerRadius="12dp"/>

</LinearLayout>